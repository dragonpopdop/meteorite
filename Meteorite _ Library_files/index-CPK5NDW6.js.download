<!DOCTYPE html>
<html lang="en">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>Preview</title>
    <style>
      /* Loading indicator - shown by default, hidden when main.js loads */
      #preview-loading {
        position: fixed;
        top: 0;
        left: 0;
        right: 0;
        bottom: 0;
        display: flex;
        flex-direction: column;
        align-items: center;
        justify-content: center;
        background: #040813;
        color: #8a8a9a;
        font-family: 'Inter', -apple-system, BlinkMacSystemFont, 'Segoe UI', Roboto, sans-serif;
        font-size: 14px;
        z-index: 99999;
      }

      /* Browser window animation */
      .browser-window {
        width: 120px;
        height: 80px;
        background: #0d1117;
        border-radius: 8px;
        overflow: hidden;
        box-shadow: 0 4px 24px rgba(0, 0, 0, 0.4);
        margin-bottom: 20px;
      }

      .browser-bar {
        height: 12px;
        background: #161b22;
        display: flex;
        align-items: center;
        padding: 0 6px;
        gap: 3px;
      }

      .browser-dot {
        width: 4px;
        height: 4px;
        border-radius: 50%;
        background: #3a424d;
      }

      .browser-content {
        padding: 8px;
        display: flex;
        flex-direction: column;
        gap: 5px;
      }

      .content-line {
        height: 4px;
        border-radius: 2px;
        background: linear-gradient(90deg, #f97316 0%, #f97316 50%, #1a2332 50%, #1a2332 100%);
        background-size: 200% 100%;
        transform-origin: left;
        animation: drawLine 2s ease-in-out infinite;
      }

      .content-line:nth-child(1) {
        width: 60%;
        animation-delay: 0s;
      }
      .content-line:nth-child(2) {
        width: 100%;
        animation-delay: 0.2s;
      }
      .content-line:nth-child(3) {
        width: 80%;
        animation-delay: 0.4s;
      }
      .content-line:nth-child(4) {
        width: 45%;
        animation-delay: 0.6s;
      }
      .content-line:nth-child(5) {
        width: 90%;
        animation-delay: 0.8s;
      }

      @keyframes drawLine {
        0% {
          background-position: 100% 0;
        }
        40%, 60% {
          background-position: 0% 0;
        }
        100% {
          background-position: 100% 0;
        }
      }

      #preview-loading .message {
        opacity: 0;
        animation: fadeIn 0.3s ease-out 1s forwards;
      }

      #preview-loading .retry-hint {
        opacity: 0;
        animation: fadeIn 0.3s ease-out 5s forwards;
        font-size: 12px;
        color: #5a5a6a;
        margin-top: 8px;
      }

      @keyframes fadeIn {
        to { opacity: 1; }
      }
    </style>
    <script type="module" crossorigin src="/preview-assets/index-C_n9Of_a.js"></script>
  </head>
  <body>
    <!-- Loading indicator - visible until main.js loads and hides it -->
    <div id="preview-loading">
      <div class="browser-window">
        <div class="browser-bar">
          <div class="browser-dot"></div>
          <div class="browser-dot"></div>
          <div class="browser-dot"></div>
        </div>
        <div class="browser-content">
          <div class="content-line"></div>
          <div class="content-line"></div>
          <div class="content-line"></div>
          <div class="content-line"></div>
          <div class="content-line"></div>
        </div>
      </div>
      <div class="message">Building preview...</div>
      <div class="retry-hint">Taking longer than expected? Try refreshing the page.</div>
    </div>
    <!-- __inject-hash -->
  </body>
</html>
